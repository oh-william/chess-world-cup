#!/usr/bin/env node
/* js-alphabeta — the SAME iterative-deepening alpha-beta + quiescence + MVV-LVA
 * over the SAME libchess eval as the C++/Rust/Python versions, in Node.js. The
 * perft-clean core is reused as a WebAssembly module (emscripten), so the hot
 * movegen runs at near-native speed and only the search loop is JS. Another
 * point on the language-tax axis: JS + a WASM core. Deterministic (no RNG). */
"use strict";
const path = require("path");
const readline = require("readline");
const createLibchess = require(path.join(__dirname, "libchess.js"));

const INF = 1e9, MATE = 30000, MAX_PLY = 64;
const VAL = [100, 320, 330, 500, 900, 0];

createLibchess().then((M) => {
  const h16 = () => M.HEAPU16;
  const writeStr = (s) => {
    const ptr = M._malloc(s.length * 4 + 1);
    M.stringToUTF8(s, ptr, s.length * 4 + 1);
    return ptr;
  };

  class Board {
    constructor() { this.h = M._lc_new(); this.buf = M._malloc(256 * 2); }
    startpos() { M._lc_startpos(this.h); }
    setFen(f) { const p = writeStr(f); M._lc_set_fen(this.h, p); M._free(p); }
    stm() { return M._lc_side_to_move(this.h); }
    inCheck() { return M._lc_in_check(this.h) !== 0; }
    eval() { return M._lc_eval(this.h); }
    pieceAt(sq) { return M._lc_piece_at(this.h, sq); }
    make(m) { M._lc_make(this.h, m); }
    unmake(m) { M._lc_unmake(this.h, m); }
    legal() {
      const n = M._lc_legal_moves(this.h, this.buf, 256);
      const out = new Array(n);
      const heap = h16();
      if (heap) {
        const base = this.buf >>> 1;
        for (let i = 0; i < n; i++) out[i] = heap[base + i];
      } else {
        for (let i = 0; i < n; i++) out[i] = M.getValue(this.buf + 2 * i, "i16") & 0xffff;
      }
      return out;
    }
    fromUci(u) { const p = writeStr(u); const m = M._lc_move_from_uci(this.h, p); M._free(p); return m; }
    toUci(m) { const p = M._malloc(6); M._lc_move_to_uci(m, p); const s = M.UTF8ToString(p); M._free(p); return s; }
  }

  const mvTo = (m) => (m >> 6) & 0x3f;
  const mvFrom = (m) => m & 0x3f;
  const mvFlag = (m) => (m >> 14) & 0x3;      // 1 promo, 2 ep
  const mvPromo = (m) => ((m >> 12) & 0x3) + 1;

  function moveScore(b, m) {
    const victim = b.pieceAt(mvTo(m));
    let s = 0;
    if (victim >= 0) s += 100 * VAL[victim] - VAL[b.pieceAt(mvFrom(m))];
    const f = mvFlag(m);
    if (f === 1) s += 100 * VAL[mvPromo(m)];
    else if (f === 2) s += 100 * VAL[0];
    return s;
  }
  function order(b, moves, hint) {
    const keyed = moves.map((m) => [m === hint ? INF : moveScore(b, m), m]);
    keyed.sort((a, c) => c[0] - a[0]);
    return keyed.map((k) => k[1]);
  }
  const isCapture = (b, m) => b.pieceAt(mvTo(m)) >= 0 || mvFlag(m) === 2;

  const ctx = { nodes: 0, nodeMode: false, nodeLimit: 0, timeMode: false, deadline: 0, stop: false };
  function check() {
    if (ctx.nodeMode && ctx.nodes >= ctx.nodeLimit) ctx.stop = true;
    else if (ctx.timeMode && (ctx.nodes & 2047) === 0 && Date.now() >= ctx.deadline) ctx.stop = true;
  }

  function quiesce(b, alpha, beta) {
    ctx.nodes++; check();
    if (ctx.stop) return alpha;
    const stand = b.eval();
    if (stand >= beta) return beta;
    if (stand > alpha) alpha = stand;
    for (const m of order(b, b.legal(), 0)) {
      if (!isCapture(b, m) && mvFlag(m) !== 1) continue;
      b.make(m);
      const score = -quiesce(b, -beta, -alpha);
      b.unmake(m);
      if (ctx.stop) return alpha;
      if (score >= beta) return beta;
      if (score > alpha) alpha = score;
    }
    return alpha;
  }
  function negamax(b, depth, ply, alpha, beta) {
    check();
    if (ctx.stop) return 0;
    if (depth <= 0) return quiesce(b, alpha, beta);
    ctx.nodes++;
    const moves = b.legal();
    if (moves.length === 0) return b.inCheck() ? -MATE + ply : 0;
    let best = -INF;
    for (const m of order(b, moves, 0)) {
      b.make(m);
      const score = -negamax(b, depth - 1, ply + 1, -beta, -alpha);
      b.unmake(m);
      if (ctx.stop) return best > -INF ? best : alpha;
      if (score > best) best = score;
      if (score > alpha) alpha = score;
      if (alpha >= beta) break;
    }
    return best;
  }

  function search(b, msLeft, nodesLeft) {
    ctx.nodes = 0; ctx.stop = false;
    ctx.nodeMode = nodesLeft >= 0; ctx.nodeLimit = nodesLeft;
    ctx.timeMode = msLeft >= 0; ctx.deadline = Date.now() + Math.max(1, msLeft - 5);
    const root = b.legal();
    if (root.length === 0) return [0, 0];
    if (root.length === 1) return [root[0], 0];
    let overallBest = root[0], hint = 0;
    for (let depth = 1; depth < MAX_PLY; depth++) {
      let alpha = -INF, bestScore = -INF, localBest = 0;
      for (const m of order(b, root, hint)) {
        b.make(m);
        const score = -negamax(b, depth - 1, 1, -INF, -alpha);
        b.unmake(m);
        if (ctx.stop) break;
        if (score > bestScore) { bestScore = score; localBest = m; }
        if (score > alpha) alpha = score;
      }
      if (ctx.stop) break;
      overallBest = localBest; hint = localBest;
      if (bestScore >= MATE - MAX_PLY) break;
    }
    return [overallBest, ctx.nodes];
  }

  const board = new Board();
  function applyPosition(tokens) {
    let i = 0;
    if (tokens[0] === "startpos") { board.startpos(); i = 1; }
    else if (tokens[0] === "fen") { board.setFen(tokens.slice(1, 7).join(" ")); i = 7; }
    const mi = tokens.indexOf("moves");
    if (mi >= 0) for (const u of tokens.slice(mi + 1)) { const m = board.fromUci(u); if (m) board.make(m); }
  }

  const out = process.stdout;
  const rl = readline.createInterface({ input: process.stdin, terminal: false });
  rl.on("line", (line) => {
    const t = line.trim().split(/\s+/);
    switch (t[0]) {
      case "uci":
        out.write("id name js-alphabeta\nid author chess-world-cup\nid lang JavaScript\nid family alpha-beta\nid country US\nuciok\n");
        break;
      case "isready": out.write("readyok\n"); break;
      case "ucinewgame": board.startpos(); break;
      case "position": applyPosition(t.slice(1)); break;
      case "go": {
        let ms = -1, nodes = -1;
        for (let i = 1; i + 1 < t.length; i++) {
          if (t[i] === "movetime") ms = parseInt(t[i + 1], 10);
          else if (t[i] === "nodes") nodes = parseInt(t[i + 1], 10);
        }
        const t0 = Date.now();
        const [best, n] = search(board, ms, nodes);
        out.write(`info time ${Date.now() - t0} nodes ${n}\nbestmove ${board.toUci(best)}\n`);
        break;
      }
      case "quit": process.exit(0);
    }
  });
});
